{
  "name": "dirty-bits",
  "version": "0.0.0",
  "description": "GitHub action that identifies the parts of a repository that need to be built, tested, deployed, etc. depending on which files have changed",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "all": "npm run build && npm run format-check && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/jhesch/dirty-bits.git"
  },
  "keywords": [
    "github",
    "actions",
    "workflow",
    "monorepo",
    "ci",
    "cd"
  ],
  "author": "Jacob Hesch",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jhesch/dirty-bits/issues"
  },
  "homepage": "https://github.com/jhesch/dirty-bits#readme",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^9.1.1",
    "js-yaml": "^4.1.0",
    "minimatch": "^3.0.4"
  },
  "devDependencies": {
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-definitions": "^3.67.3",
    "@types/jest": "^27.0.1",
    "@types/js-yaml": "^4.0.3",
    "@types/minimatch": "^3.0.5",
    "@types/node": "^18.11.9",
    "@vercel/ncc": "^0.34.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^30.3.0",
    "jest-circus": "^27.1.0",
    "nock": "^14.0.13",
    "prettier": "^2.7.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
